<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient android:startColor="#7A1B0E" android:endColor="#3A0A06" android:angle="270" />
        </shape>
    </item>
    <item android:top="0dp" android:left="0dp" android:right="40dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <gradient android:startColor="#00000000" android:endColor="#22000000" android:angle="270" />
        </shape>
    </item>
    <item android:left="0dp" android:right="1dp">
        <shape>
            <solid android:color="#00000000" />
            <size android:width="1dp" />
        </shape>
    </item>
</layer-list>

