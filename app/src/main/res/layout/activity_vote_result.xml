<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fondo">

    <TextView
        android:id="@+id/tvVoteTimerResult"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:fontFamily="monospace"
        android:text="10:00"
        android:textColor="#4E342E"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvSuspectName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:text="NOMBRE"
        android:textColor="#4E342E"
        android:textSize="48sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/tvVoteTimerResult"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvIntrigueQuestion"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="30dp"
        android:text="¿Habrá ganado o perdido el engañón?"
        android:textColor="#FFFFFF"
        android:textSize="36sp"
        android:textStyle="bold"
        android:fontFamily="serif"
        android:gravity="center"
        android:shadowColor="#000000"
        android:shadowDx="6"
        android:shadowDy="6"
        android:shadowRadius="12"
        android:letterSpacing="0.02"
        android:lineSpacingExtra="8sp"
        android:visibility="invisible"
        app:layout_constraintTop_toBottomOf="@id/tvSuspectName"
        app:layout_constraintBottom_toTopOf="@+id/btnRevealVote"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cvResultCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:visibility="gone"
        android:alpha="0"
        app:cardCornerRadius="32dp"
        app:cardElevation="15dp"
        app:cardBackgroundColor="#FDF5E6"
        app:layout_constraintTop_toBottomOf="@id/tvSuspectName"
        app:layout_constraintBottom_toTopOf="@+id/btnContinue"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="20dp"
                android:src="@drawable/decor_top"
                android:scaleType="centerInside"
                android:layout_marginBottom="16dp"
                app:tint="#D9C5A3" />

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                
                <ImageView
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:src="@drawable/logo"
                    android:alpha="0.12"
                    android:layout_gravity="center" />

                <TextView
                    android:id="@+id/tvMainVerdict"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NO ERA EL ENGAÑÓN"
                    android:textColor="#4E342E"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_gravity="center" />
            </FrameLayout>

            <View
                android:layout_width="140dp"
                android:layout_height="3dp"
                android:layout_marginVertical="16dp"
                android:background="#D9C5A3" />

            <TextView
                android:id="@+id/tvRoleRevealed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Era: PARTICIPANTE"
                android:textColor="#4E342E"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="¡El impostor sigue entre nosotros!\nDebéis afinar la puntería."
                android:textColor="#8D6E63"
                android:textSize="17sp"
                android:textStyle="italic"
                android:textAlignment="center"
                android:lineSpacingExtra="4dp"/>

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="20dp"
                android:src="@drawable/decor_bottom"
                android:scaleType="centerInside"
                android:layout_marginTop="20dp"
                app:tint="#D9C5A3" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <Button
        android:id="@+id/btnRevealVote"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="40dp"
        android:layout_marginBottom="60dp"
        android:backgroundTint="#C2AE8D"
        android:padding="18dp"
        android:text="REVELAR VEREDICTO"
        android:textColor="@android:color/black"
        android:textSize="20sp"
        android:textStyle="bold"
        app:cornerRadius="15dp"
        app:layout_constraintBottom_toBottomOf="parent" />

    <Button
        android:id="@+id/btnContinue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="40dp"
        android:layout_marginBottom="60dp"
        android:backgroundTint="#C2AE8D"
        android:padding="18dp"
        android:text="CONTINUAR"
        android:textColor="@android:color/black"
        android:textSize="20sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:cornerRadius="15dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
